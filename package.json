{
  "name": "itsuki-bot",
  "version": "1.0.0",
  "description": "Itsuki Bot — Premium Discord Economy Bot",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch & node --watch dist/index.js",
    "deploy": "tsc && node dist/deploy-commands.js global",
    "deploy:guild": "tsc && node dist/deploy-commands.js guild",
    "deploy:clear-guild": "tsc && node dist/deploy-commands.js clear-guild",
    "typecheck": "tsc --noEmit",
    "setup": "npm install && npm run build"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "canvas": "^3.2.3",
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.5",
    "lavende": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
