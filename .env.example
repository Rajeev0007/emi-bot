# ─────────────────────────────────────────────
#  Itsuki Bot — Environment Variables
#  Copy this file to .env and fill in the values
#  cp .env.example .env
# ─────────────────────────────────────────────

# ── Required ──────────────────────────────────
# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Your bot's Application / Client ID
DISCORD_CLIENT_ID=your_client_id_here

# ── Optional ──────────────────────────────────
# A specific Guild (server) ID for instant command registration during development.
# Leave blank to register commands globally (takes up to 1 hour to propagate).
DISCORD_GUILD_ID=

# Comma-separated Discord user IDs that have owner-level access
BOT_OWNERS=

# Prefix for message-based (prefix) commands. Defaults to ! if not set.
PREFIX=!
